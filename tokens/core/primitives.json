    "motion": {
      "duration": {
        "$description": "Duration scale. Alphabet = Ant's motionUnit×n derived scale (fast 100 / base 200 / slow 300, from seed.motionUnit 0.1s). Grammar = documented tuned exceptions for specific interactions (instant 50 / press 160 / slower 500).",
        "instant": {
          "$value": "50ms",
          "$type": "duration",
          "$description": "Micro-interactions (taps) — grammar exception, below the ×1 grid"
        },
        "fast": {
          "$value": "100ms",
          "$type": "duration",
          "$description": "Quick transitions (hover, toggle) — Ant alphabet, motionUnit×1 (0.1s)"
        },
        "press": {
          "$value": "160ms",
          "$type": "duration",
          "$description": "Button press feedback — grammar exception (Emil Kowalski: 100–160ms for tactile :active feedback)"
        },
        "base": {
          "$value": "200ms",
          "$type": "duration",
          "$description": "Standard transitions — Ant alphabet, motionUnit×2 (0.2s)"
        },
        "slow": {
          "$value": "300ms",
          "$type": "duration",
          "$description": "Complex transitions (expand, slide) — Ant alphabet, motionUnit×3 (0.3s)"
        },
        "slower": {
          "$value": "500ms",
          "$type": "duration",
          "$description": "Page-level transitions — grammar exception, above the ×3 grid"
        }
      },
      "easing": {
        "$description": "Easing vocabulary. Alphabet = the 8 canonical Ant Design cubic-beziers (easeOut, easeInOut, easeOutCirc, easeInOutCirc, easeOutBack, easeInBack, easeOutQuint, easeInQuint), kept value-exact for cross-engine identity (CSS / Motion / GSAP). Grammar = tuned additions (standard, easeInOutStrong, easeDrawer) selected per Emil Kowalski's framework.",
        "easeOut": {
          "$value": [
            0.215,
            0.61,
            0.355,
            1
          ],
          "$type": "cubicBezier",
          "$description": "Default exit — smooth deceleration"
        },
        "easeInOut": {
          "$value": [
            0.645,
            0.045,
            0.355,
            1
          ],
          "$type": "cubicBezier",
          "$description": "Symmetric — enter + exit"
        },
        "easeOutCirc": {
          "$value": [
            0.08,
            0.82,
            0.17,
            1
          ],
          "$type": "cubicBezier",
          "$description": "Snappy exit — organic feel"
        },
        "easeInOutCirc": {
          "$value": [
            0.78,
            0.14,
            0.15,
            0.86
          ],
          "$type": "cubicBezier",
          "$description": "Snappy symmetric"
        },
        "easeOutBack": {
          "$value": [
            0.12,
            0.4,
            0.29,
            1.46
          ],
          "$type": "cubicBezier",
          "$description": "Bouncy overshoot — playful"
        },
        "easeInBack": {
          "$value": [
            0.71,
            -0.46,
            0.88,
            0.6
          ],
          "$type": "cubicBezier",
          "$description": "Anticipation pull-back"
        },
        "easeOutQuint": {
          "$value": [
            0.23,
            1,
            0.32,
            1
          ],
          "$type": "cubicBezier",
          "$description": "Aggressive deceleration"
        },
        "easeInQuint": {
          "$value": [
            0.755,
            0.05,
            0.855,
            0.06
          ],
          "$type": "cubicBezier",
          "$description": "Slow start, fast end"
        },
        "standard": {
          "$value": [
            0.4,
            0,
            0.2,
            1
          ],
          "$type": "cubicBezier",
          "$description": "Material/Apple standard curve — symmetric ease for general state transitions, clip-path animations, theme cross-fades"
        },
        "easeInOutStrong": {
          "$value": [
            0.77,
            0,
            0.175,
            1
          ],
          "$type": "cubicBezier",
          "$description": "Emil Kowalski — stronger symmetric curve for on-screen movement (more punch than easeInOut)"
        },
        "easeDrawer": {
          "$value": [
            0.32,
            0.72,
            0,
            1
          ],
          "$type": "cubicBezier",
          "$description": "iOS-like drawer curve from Ionic — sheet/drawer slide-in/out"
        }
      },
      "spring": {
        "$description": "Spring approximations as cubic-bezier — grammar layer. Overshoot curves matching the Framer Motion springs used in production (within a few ms). Portable across CSS / Motion / GSAP per ADR 0027; true physics springs are Motion-bound and tagged separately.",
        "card": {
          "$value": [
