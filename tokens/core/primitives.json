    "engine": {
      "$description": "Heat×Depth dynamic-engine gamut anchors (ADR 0028). Runtime interpolates: hue by --ui-heat (0–100), lightness + chroma by --ui-depth (0–100; lightMode = depth 0, darkMode = depth 100). Re-anchored to the honey base S/V (HSV 0.873/0.961) saturation per the opacity-model formula — vivid surfaces carry honey-level chroma (~0.28) across the blue→pink hue sweep; bg/surface stay deliberately subtle. Offset base from the component palette to stay concurrency-free. Values are formula-derived; fine-tune by eye via visual QA once Stage C makes them live.",
      "hue": {
        "rest": { "$value": 250, "$type": "number", "$description": "Hue (deg) at heat=0 — cool blue" },
        "heatSpan": { "$value": 280, "$type": "number", "$description": "Degrees subtracted across heat 0→100 (heat=100 → 250−280 = −30 ≡ 330 pink)" }
      },
      "lightness": {
        "$description": "Per-surface OKLCH lightness anchors (0–1). lightMode = depth 0, darkMode = depth 100.",
        "bg":      { "lightMode": { "$value": 0.96, "$type": "number" }, "darkMode": { "$value": 0.15, "$type": "number" } },
        "heading": { "lightMode": { "$value": 0.20, "$type": "number" }, "darkMode": { "$value": 0.95, "$type": "number" } },
        "body":    { "lightMode": { "$value": 0.35, "$type": "number" }, "darkMode": { "$value": 0.68, "$type": "number" } },
        "muted":   { "lightMode": { "$value": 0.50, "$type": "number" }, "darkMode": { "$value": 0.60, "$type": "number" } },
        "accent":  { "lightMode": { "$value": 0.50, "$type": "number" }, "darkMode": { "$value": 0.72, "$type": "number" } },
        "surface": { "lightMode": { "$value": 0.98, "$type": "number" }, "darkMode": { "$value": 0.18, "$type": "number" } },
        "btnBg":   { "lightMode": { "$value": 0.45, "$type": "number" }, "darkMode": { "$value": 0.78, "$type": "number" } },
        "btnFg":   { "lightMode": { "$value": 0.98, "$type": "number" }, "darkMode": { "$value": 0.15, "$type": "number" } }
      },
      "chroma": {
        "$description": "Per-surface OKLCH chroma anchors (0–1). lightMode = depth 0, darkMode = depth 100.",
        "bg":     { "lightMode": { "$value": 0.02, "$type": "number" }, "darkMode": { "$value": 0.16, "$type": "number" } },
        "accent": { "lightMode": { "$value": 0.28, "$type": "number", "$description": "Honey-S/V vivid (re-anchored from 0.26)" }, "darkMode": { "$value": 0.28, "$type": "number", "$description": "Honey-S/V vivid (re-anchored from 0.20)" } }
      }
    },
    "atmosphere": {
      "$description": "Ambient atmosphere gamut (ADR 0028) — orbs + page-tint (dual-axis like the engine surfaces) plus the sunset transition bloom. Faithful tokenization of the prior globals.css atmosphere; offset base from the component palette to stay concurrency-free.",
      "orb": {
        "primary": {
          "lightness": { "lightMode": { "$value": 0.55, "$type": "number" }, "darkMode": { "$value": 0.72, "$type": "number" } },
          "chroma":    { "lightMode": { "$value": 0.28, "$type": "number" }, "darkMode": { "$value": 0.28, "$type": "number" } },
          "opacity":   { "lightMode": { "$value": 0.55, "$type": "number" }, "darkMode": { "$value": 0.85, "$type": "number" } }
        },
        "secondary": {
          "$description": "Secondary orb — hue offset from --dynamic-hue for complementary warmth.",
          "hueOffset": { "$value": 40, "$type": "number", "$description": "Degrees added to --dynamic-hue" },
          "lightness": { "lightMode": { "$value": 0.45, "$type": "number" }, "darkMode": { "$value": 0.65, "$type": "number" } },
          "chroma":    { "lightMode": { "$value": 0.27, "$type": "number" }, "darkMode": { "$value": 0.27, "$type": "number" } },
          "opacity":   { "lightMode": { "$value": 0.50, "$type": "number" }, "darkMode": { "$value": 0.80, "$type": "number" } }
        }
      },
      "pageTint": {
        "lightnessOffset": { "$value": 0.02, "$type": "number", "$description": "Added to --L-bg for the page-tint gradient lightness" },
        "chroma": { "lightMode": { "$value": 0.14, "$type": "number" }, "darkMode": { "$value": 0.01, "$type": "number" } },
        "alpha": { "$value": 0.85, "$type": "number" }
      },
      "sunset": {
        "$description": "Golden midpoint bloom during the light↔dark depth sweep — a transition-only color-motion (Gaussian envelope over --ui-depth). The 'nectar' warm moment.",
        "envelope": {
          "peak": { "$value": 40, "$type": "number", "$description": "Depth at which the bloom peaks" },
          "sigma": { "$value": 20, "$type": "number", "$description": "Gaussian σ over depth 0–100" }
        },
        "layer1": {
          "lightness": { "$value": 0.75, "$type": "number" },
          "chroma": { "$value": 0.18, "$type": "number" },
          "hue": { "$value": 70, "$type": "number", "$description": "Golden yellow" },
          "intensity": { "$value": 0.55, "$type": "number", "$description": "Peak alpha multiplier" }
        },
        "layer2": {
          "lightness": { "$value": 0.78, "$type": "number" },
          "chroma": { "$value": 0.16, "$type": "number" },
          "hue": { "$value": 50, "$type": "number" },
          "intensity": { "$value": 0.30, "$type": "number" }
        }
      }
    }
  }
}
