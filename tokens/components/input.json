{
  "component": {
    "input": {
      "$description": "Input component tokens — shares controlHeight system with Button",

      "controlHeight":   { "$value": "{seed.controlHeight}",     "$type": "number", "$description": "Default height (md = 40px)" },
      "controlHeightSM": { "$value": "{map.controlHeight.SM}",   "$type": "number", "$description": "Small height (sm = 32px)" },
      "controlHeightLG": { "$value": "{map.controlHeight.LG}",   "$type": "number", "$description": "Large height (lg = 48px)" },

      "paddingInline":   { "$value": "{map.size.MS}",  "$type": "number", "$description": "Default horizontal padding (16px = px-4)" },
      "paddingInlineSM": { "$value": "{map.size.SM}",  "$type": "number", "$description": "Small horizontal padding (12px = px-3)" },

      "fontSize":        { "$value": "{map.fontSize.SM}",     "$type": "number", "$description": "Default/small font size (13px ~ text-sm)" },
      "fontSizeLG":      { "$value": "{seed.fontSize}",       "$type": "number", "$description": "Large font size (16px = text-base)" },

      "borderRadius":    { "$value": "{map.borderRadius.MD}",  "$type": "number", "$description": "Default radius (8px = rounded-md)" },
      "borderRadiusSM":  { "$value": "{map.borderRadius.SM}",  "$type": "number", "$description": "Small radius (4px = rounded-sm)" },
      "borderRadiusLG":  { "$value": "{map.borderRadius.LG}",  "$type": "number", "$description": "Large radius (12px = rounded-lg)" },

      "borderColor":     { "$value": "{map.color.neutralBorder.colorBorder}", "$type": "color", "$description": "Default border" },
      "errorBorderColor": { "$value": "{map.color.error.Base}", "$type": "color", "$description": "Error state border" },

      "bg":              { "$value": "{map.color.neutralBg.colorBgContainer}", "$type": "color", "$description": "Input background" },
      "placeholderColor": { "$value": "{map.color.neutralText.colorTextTertiary}", "$type": "color", "$description": "Placeholder text — 45% opacity" }
    }
  }
}
