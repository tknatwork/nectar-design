{
  "component": {
    "card": {
      "$description": "Card component tokens — surface, padding, border, shadow",

      "borderRadius":  { "$value": "{map.borderRadius.LG}",   "$type": "number", "$description": "Card radius (12px = rounded-lg)" },
      "borderWidth":   { "$value": "{seed.lineWidth}",         "$type": "number", "$description": "Card border width" },
      "borderColor":   { "$value": "{map.color.neutralBorder.colorBorder}", "$type": "color", "$description": "Default border" },

      "bg":            { "$value": "{map.color.neutralBg.colorBgContainer}", "$type": "color", "$description": "Card surface" },

      "paddingSM":     { "$value": "{map.size.MS}",  "$type": "number", "$description": "Small padding (16px = p-4)" },
      "paddingMD":     { "$value": "{map.size.LG}",  "$type": "number", "$description": "Default padding (24px = p-6)" },
      "paddingLG":     { "$value": "{map.size.XL}",  "$type": "number", "$description": "Large padding (32px = p-8)" },

      "hoverBorderColor": { "$value": "{map.color.primary.Base}", "$type": "color", "$description": "Interactive variant hover border" }
    }
  }
}
