{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":separateMajorReleases"
  ],
  "baseBranchPatterns": [
    "dev"
  ],
  "labels": ["dependencies"],
  "rangeStrategy": "bump",
  "prHourlyLimit": 2,
  "prConcurrentLimit": 3,
  "packageRules": [
    {
      "description": "Group minor + patch updates weekly",
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "minor-patch",
      "schedule": ["before 9am on Monday"],
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true
    },
    {
      "description": "Major updates monthly — require manual review",
      "matchUpdateTypes": ["major"],
      "groupName": "major",
      "schedule": ["before 9am on the first day of the month"],
      "automerge": false
    },
    {
      "description": "Group Storybook packages together",
      "groupName": "storybook",
      "matchPackageNames": [
        "/^@storybook//",
        "/^storybook$/",
        "/^@chromatic-com//"
      ]
    },
    {
      "description": "Group testing packages",
      "groupName": "testing",
      "matchPackageNames": [
        "/^vitest/",
        "/^@testing-library//",
        "/^vitest-axe$/"
      ]
    },
    {
      "description": "Group React packages",
      "groupName": "react",
      "matchPackageNames": [
        "/^react$/",
        "/^react-dom$/",
        "/^@types/react/"
      ]
    },
    {
      "description": "Group build tools",
      "groupName": "build-tools",
      "matchPackageNames": [
        "/^tsup$/",
        "/^typescript$/",
        "/^style-dictionary$/"
      ]
    },
    {
      "description": "Auto-merge type definition updates",
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true,
      "matchPackageNames": [
        "/^@types//"
      ]
    }
  ],
  "postUpdateOptions": ["pnpmDedupe"]
}
