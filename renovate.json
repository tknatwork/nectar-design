{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":separateMajorReleases",
    "helpers:pinGitHubActionDigests"
  ],
  "baseBranchPatterns": [
    "dev"
  ],
  "labels": ["dependencies"],
  "rangeStrategy": "bump",
  "prHourlyLimit": 2,
  "prConcurrentLimit": 3,
  "packageRules": [
    {
      "description": "Group minor + patch updates weekly",
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "minor-patch",
      "schedule": ["before 9am on Monday"],
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true
    },
    {
      "description": "Major updates monthly — require manual review",
      "matchUpdateTypes": ["major"],
      "groupName": "major",
      "schedule": ["before 9am on the first day of the month"],
      "automerge": false
    },
    {
      "description": "Group Storybook packages together",
      "groupName": "storybook",
      "matchPackageNames": [
        "/^@storybook//",
        "/^storybook$/",
        "/^@chromatic-com//"
      ]
    },
    {
      "description": "Group testing packages",
      "groupName": "testing",
      "matchPackageNames": [
        "/^vitest/",
        "/^@testing-library//",
        "/^vitest-axe$/"
      ]
    },
    {
      "description": "Group React packages",
      "groupName": "react",
      "matchPackageNames": [
        "/^react$/",
        "/^react-dom$/",
        "/^@types/react/"
      ]
    },
    {
      "description": "Group build tools",
      "groupName": "build-tools",
      "matchPackageNames": [
        "/^tsup$/",
        "/^typescript$/",
        "/^style-dictionary$/"
      ]
    },
    {
      "description": "Auto-merge type definition updates",
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true,
      "matchPackageNames": [
        "/^@types//"
      ]
    },
    {
      "description": "Ignore pnpm/action-setup v6 — causes ERR_PNPM_LOCKFILE_CONFIG_MISMATCH",
      "matchPackageNames": ["pnpm/action-setup"],
      "matchUpdateTypes": ["major"],
      "enabled": false
    },
    {
      "description": "Cap pnpm at v10 — defensive mirror of mp PR #689's rule. pnpm v11+ imports node:sqlite (added in Node 22.5+), and the corepack-fetched install would crash on github-hosted ubuntu-24.04 runners whose image-default Node is 20.20.2. The setup-toolchain composite action was fixed to install Node BEFORE corepack on 2026-05-11 (cross-Claude #691 / mp PR #694's mirror in nd), but this cap stays in place as a defensive backstop until a Renovate pnpm v11 PR opens here AND succeeds end-to-end on cloud CI. Once verified, drop this cap in coordinated PRs across both repos (mp + nd).",
      "matchPackageNames": ["pnpm"],
      "matchUpdateTypes": ["major"],
      "enabled": false
    }
  ],
  "postUpdateOptions": ["pnpmDedupe"]
}
