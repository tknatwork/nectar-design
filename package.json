{
  "name": "nectar-design",
  "version": "0.1.0",
  "description": "Design token pipeline + React component library. 5-tier token architecture with Tailwind v4 integration.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./tokens.css": "./dist/tokens.css",
    "./theme.css": "./dist/theme.css",
    "./gsap": "./dist/gsap/presets.js",
    "./framer": "./dist/framer/variants.js",
    "./animation.css": "./dist/animation-keyframes.css",
    "./tiptap.css": "./dist/tiptap-theme.css",
    "./circadian": {
      "import": "./dist/circadian/index.js",
      "types": "./dist/circadian/index.d.ts"
    },
    "./circadian.css": "./dist/circadian.css",
    "./echarts-theme": "./dist/echarts-theme.json"
  },
  "files": [
    "dist",
    "tokens",
    "scripts/build-tokens-sd.mjs",
    "scripts/build-motion-presets.mjs"
  ],
  "scripts": {
    "prebuild": "node scripts/build-tokens-sd.mjs",
    "build": "tsup && node scripts/build-tokens-sd.mjs && node scripts/build-motion-presets.mjs && node scripts/audit-theme-namespaces.mjs && cp css/tokens.css dist/tokens.css && cp css/theme.css dist/theme.css && cp css/tiptap-theme.css dist/tiptap-theme.css && cp css/circadian.css dist/circadian.css",
    "audit:theme": "node scripts/audit-theme-namespaces.mjs",
    "validate:tokens": "node scripts/validate-token-types.mjs",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist",
    "size": "size-limit",
    "size:check": "size-limit --limit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "peerDependencies": {
    "react": ">=19.2.6",
    "react-dom": ">=19.2.6",
    "tailwindcss": ">=4.3.0"
  },
  "dependencies": {
    "@base-ui/react": "1.5.0",
    "@iconify/react": "^6.0.2",
    "chroma-js": "^3.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "suncalc": "^1.9.0",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@size-limit/file": "^12.1.0",
    "@storybook/addon-a11y": "^10.4.1",
    "@storybook/addon-docs": "^10.4.1",
    "@storybook/addon-onboarding": "^10.4.1",
    "@storybook/addon-vitest": "^10.4.1",
    "@storybook/react-vite": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/chroma-js": "^3.1.2",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/suncalc": "^1.9.2",
    "@vitest/browser": "^4.1.7",
    "axe-core": "^4.11.4",
    "jsdom": "^29.1.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "size-limit": "^12.1.0",
    "storybook": "^10.4.1",
    "style-dictionary": "^5.4.1",
    "tsup": "^8.5.1",
    "typescript": "~6.0.3",
    "vitest": "^4.1.7",
    "vitest-axe": "^0.1.0"
  },
  "keywords": [
    "design-system",
    "design-tokens",
    "react",
    "tailwindcss",
    "cva",
    "components",
    "ui"
  ],
  "size-limit": [
    {
      "path": "dist/index.js",
      "limit": "30 kB"
    },
    {
      "path": "dist/tokens.css",
      "limit": "15 kB"
    }
  ],
  "engines": {
    "node": "24.16.0"
  },
  "packageManager": "pnpm@10.34.1",
  "author": "Tushar Kant Naik <hi@tusharkantnaik.com>",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/tknatwork/nectar-design.git"
  },
  "homepage": "https://design.tusharkantnaik.com",
  "bugs": {
    "url": "https://github.com/tknatwork/nectar-design/issues"
  }
}
