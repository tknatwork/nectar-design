{
  "name": "nectar-design",
  "version": "0.1.0",
  "description": "Design token pipeline + React component library. 5-tier token architecture with Tailwind v4 integration.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./tokens.css": "./dist/tokens.css",
    "./theme.css": "./dist/theme.css",
    "./gsap": "./dist/gsap/presets.js",
    "./framer": "./dist/framer/variants.js",
    "./animation.css": "./dist/animation-keyframes.css"
  },
  "files": [
    "dist",
    "tokens",
    "scripts/build-tokens-sd.mjs",
    "scripts/build-motion-presets.mjs"
  ],
  "scripts": {
    "prebuild": "node scripts/build-tokens-sd.mjs",
    "build": "tsup && node scripts/build-motion-presets.mjs && cp css/tokens.css dist/tokens.css && cp css/theme.css dist/theme.css",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "tailwindcss": ">=4"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.0.2",
    "@storybook/addon-a11y": "^10.3.1",
    "@storybook/addon-docs": "^10.3.1",
    "@storybook/addon-onboarding": "^10.3.1",
    "@storybook/addon-vitest": "^10.3.1",
    "@storybook/react-vite": "^10.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitest/browser-playwright": "4.1.0",
    "@vitest/coverage-v8": "4.1.0",
    "chromatic": "^15.3.0",
    "jsdom": "^29.0.1",
    "playwright": "^1.58.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "storybook": "^10.3.1",
    "style-dictionary": "^5.3.3",
    "tsup": "^8.5.0",
    "typescript": "~5.9.3",
    "vitest": "^4.1.0"
  },
  "keywords": [
    "design-system",
    "design-tokens",
    "react",
    "tailwindcss",
    "cva",
    "components",
    "ui"
  ],
  "engines": {
    "node": ">=18"
  },
  "author": "Tushar Kant Naik <hi@tusharkantnaik.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tknatwork/nectar-design.git"
  },
  "homepage": "https://github.com/tknatwork/nectar-design#readme",
  "bugs": {
    "url": "https://github.com/tknatwork/nectar-design/issues"
  }
}
